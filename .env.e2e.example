# Copy this file to .env.e2e and fill in real values before running E2E tests.
#
# Usage (dotenv-cli is a dev dependency, so just use pnpm):
#   pnpm test:e2e
#   pnpm test:e2e:ui
#   pnpm test:e2e:headed

# Frontend dev server URL (default: http://localhost:3000)
E2E_BASE_URL=http://localhost:3000

# Backend URL (default: http://localhost:7777)
E2E_BACKEND_URL=http://localhost:7777

# Backend GraphQL endpoint (default: http://localhost:7777/graphql)
E2E_GRAPHQL_URL=http://localhost:7777/graphql

# Admin credentials for the auth setup step
E2E_ADMIN_EMAIL=superadmin@smee.com.my
E2E_ADMIN_PASSWORD=superadmin123

# API key for the /api/v1/es/advance-notice endpoint
# Find or create one at Admin → Settings → API Keys
E2E_API_KEY=01d405f5118cc93385903921c954b6abcb065212d46b086087cafcaf2cac9da6

# Enable bin-transfer LOSS E2E after TJ runs migrate in smee-backend
E2E_LOSS_TRANSFER_ENABLED=1

# Optional: override racks for bin-transfer / putaway E2E (auto-discovered when unset)
# E2E_PUTAWAY_SOURCE_RACK_LABEL=I1-L2-07
# E2E_PUTAWAY_DEST_RACK_LABEL=G2-L1-07
